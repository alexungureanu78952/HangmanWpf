<Window x:Class="HangmanWpf.Views.SaveLoadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save/Load Game"
        Height="450"
        Width="500"
        Background="{DynamicResource PrimaryBackground}"
        Foreground="{DynamicResource Foreground}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <DockPanel Margin="20">
        <!-- Title -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Save/Load Game"
                   FontSize="20"
                FontWeight="Bold"
                   Foreground="{DynamicResource Accent}"
                   Margin="0,0,0,15"/>

        <!-- Save Section -->
        <StackPanel DockPanel.Dock="Top"
                Margin="0,0,0,15">
            <TextBlock Text="Save New Game:"
                       Foreground="{DynamicResource Accent}"
                       FontWeight="Bold"
                       Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding SaveName, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8"
                         Background="{DynamicResource SecondaryBackground}"
                         Foreground="{DynamicResource Foreground}"
                         BorderBrush="{DynamicResource Border}"
                         BorderThickness="1"
                         Height="30"
                         Margin="0,0,5,0"/>
                <Button Grid.Column="1"
                        Content="Save"
                        Command="{Binding SaveGameCommand}"
                        Background="{DynamicResource Success}"
                        Foreground="{DynamicResource Foreground}"
                        Height="30"/>
            </Grid>
        </StackPanel>

        <!-- Load Section -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Load Saved Game:"
                   Foreground="{DynamicResource Accent}"
                   FontWeight="Bold"
                   Margin="0,0,0,5"/>

        <!-- Saved Games ListBox -->
        <ListBox DockPanel.Dock="Top"
                 ItemsSource="{Binding SavedGames}"
                 SelectedItem="{Binding SelectedGame}"
                 Background="{DynamicResource SecondaryBackground}"
                 Foreground="{DynamicResource Foreground}"
                 BorderBrush="{DynamicResource Border}"
                 BorderThickness="1"
                 Height="200"
                 Margin="0,0,0,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5">
                        <TextBlock Text="{Binding SaveName}"
                                FontWeight="Bold"/>
                        <TextBlock Text="{Binding StringFormat='Level: {0}, Progress: {1}', Path=Level, ConverterParameter=Placeholder}"
                                   FontSize="11"
                                   Foreground="{DynamicResource Info}"/>
                        <TextBlock Text="{Binding SavedAt, StringFormat='Saved: {0:MM/dd/yyyy HH:mm}'}"
                                   FontSize="10"
                                   Foreground="{DynamicResource Border}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Buttons -->
        <Grid DockPanel.Dock="Bottom"
                Height="40"
                Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="Load"
                    Command="{Binding LoadGameCommand}"
                    Background="{DynamicResource Success}"
                    Foreground="{DynamicResource Foreground}"
                    Margin="0,0,5,0"/>
            <Button Grid.Column="1"
                    Content="Delete"
                    Command="{Binding DeleteGameCommand}"
                    Background="{DynamicResource Error}"
                    Foreground="{DynamicResource Foreground}"
                    Margin="5,0,5,0"/>
            <Button Grid.Column="2"
                    Content="Close"
                    Command="{Binding CloseCommand}"
                    Background="{DynamicResource ButtonBackground}"
                    Foreground="{DynamicResource Foreground}"
                    Margin="5,0,0,0"/>
        </Grid>
    </DockPanel>
</Window>
