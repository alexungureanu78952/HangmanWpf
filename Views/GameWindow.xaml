<Window x:Class="HangmanWpf.Views.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hangman - Game"
        Height="700"
        Width="900"
        Background="{DynamicResource PrimaryBackground}"
        Foreground="{DynamicResource Foreground}"
        WindowStartupLocation="CenterScreen">
        <DockPanel>
                <!-- Menu Bar -->
                <Menu DockPanel.Dock="Top"
                      Background="{DynamicResource SecondaryBackground}"
                      Foreground="{DynamicResource Foreground}">
                        <MenuItem Header="File">
                                <MenuItem Header="New Game"
                                          Command="{Binding StartNewGameCommand}"/>
                                <MenuItem Header="Open Game"
                                          Command="{Binding LoadGameCommand}"/>
                                <MenuItem Header="Save Game"
                                          Command="{Binding SaveGameCommand}"/>
                                <MenuItem Header="Statistics"
                                          Click="OnStatisticsMenuClick"/>
                                <Separator/>
                                <MenuItem Header="Cancel"
                                          Command="{Binding CancelCommand}"/>
                        </MenuItem>
                        <MenuItem Header="Category">
                                <MenuItem Header="Movies"
                                          Command="{Binding ChangeCategoryCommand}"
                                          CommandParameter="Movies"/>
                                <MenuItem Header="Cars"
                                          Command="{Binding ChangeCategoryCommand}"
                                          CommandParameter="Cars"/>
                                <MenuItem Header="Rivers"
                                          Command="{Binding ChangeCategoryCommand}"
                                          CommandParameter="Rivers"/>
                                <MenuItem Header="Mountains"
                                          Command="{Binding ChangeCategoryCommand}"
                                          CommandParameter="Mountains"/>
                                <MenuItem Header="States"
                                          Command="{Binding ChangeCategoryCommand}"
                                          CommandParameter="States"/>
                                <MenuItem Header="Animals"
                                          Command="{Binding ChangeCategoryCommand}"
                                          CommandParameter="Animals"/>
                                <MenuItem Header="Countries"
                                          Command="{Binding ChangeCategoryCommand}"
                                          CommandParameter="Countries"/>
                                <MenuItem Header="All Categories"
                                          Command="{Binding ChangeCategoryCommand}"
                                          CommandParameter="All Categories"/>
                        </MenuItem>
                        <MenuItem Header="Theme">
                                <MenuItem Header="Dark Purple"
                                          Click="OnThemePurpleClick"/>
                                <MenuItem Header="Dark Red"
                                          Click="OnThemeRedClick"/>
                        </MenuItem>
                        <MenuItem Header="Help">
                                <MenuItem Header="About"
                                          Click="OnAboutMenuClick"/>
                        </MenuItem>
                </Menu>

                <!-- Main Content -->
                <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Panel: User Info & Hangman -->
                        <StackPanel Grid.Column="0"
                                    Margin="0,0,20,0">
                                <!-- User Info -->
                                <TextBlock Text="{Binding CurrentUser.Username}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Accent}"
                                           Margin="0,0,0,10"/>
                                <Image Source="{Binding CurrentUser.ImagePath}"
                                       Width="80"
                                       Height="80"
                                       Margin="0,0,0,20"/>

                                <!-- Hangman Art -->
                                <TextBlock Text="{Binding HangmanDisplay}"
                                           FontFamily="Courier New"
                                           FontSize="12"
                                           Foreground="{DynamicResource Foreground}"
                                           Margin="0,0,0,20"/>

                                <!-- Stats -->
                                <Border Background="{DynamicResource SecondaryBackground}"
                                        Padding="10">
                                        <StackPanel>
                                                <TextBlock Text="{Binding StringFormat='Level: {0}/3', Path=Level}"
                                                           Foreground="{DynamicResource Accent}"
                                                           Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding StringFormat='Wrong: {0}/6', Path=WrongCount}"
                                                           Foreground="{DynamicResource Error}"
                                                           Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding StringFormat='Timer: {0}s', Path=TimerSeconds}"
                                                           Foreground="{DynamicResource Info}"/>
                                        </StackPanel>
                                </Border>
                        </StackPanel>

                        <!-- Center Panel: Word & Buttons -->
                        <StackPanel Grid.Column="1">
                                <!-- Word Display -->
                                <TextBlock Text="{Binding WordDisplay}"
                                           FontSize="48"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Accent}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,30"
                                           Padding="20"
                                           Background="{DynamicResource SecondaryBackground}"/>

                                <!-- Status Message -->
                                <TextBlock Text="{Binding StatusMessage}"
                                           FontSize="14"
                                           Foreground="{DynamicResource Success}"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,20"
                                           Height="40"/>

                                <!-- Letter Tiles -->
                                <ItemsControl ItemsSource="{Binding LetterTiles}"
                                              Margin="0,0,0,10">
                                        <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                        <UniformGrid Columns="13"/>
                                                </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                        <Border Margin="2"
                                                                MinWidth="28"
                                                                MinHeight="28"
                                                                Padding="4"
                                                                BorderThickness="1"
                                                                BorderBrush="{DynamicResource Border}">
                                                                <Border.Style>
                                                                        <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
                                                                                <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding State}" Value="Correct">
                                                                                                <Setter Property="Background" Value="{DynamicResource Success}"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding State}" Value="Wrong">
                                                                                                <Setter Property="Background" Value="{DynamicResource Error}"/>
                                                                                        </DataTrigger>
                                                                                </Style.Triggers>
                                                                        </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Letter}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource Foreground}"/>
                                                        </Border>
                                                </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                        <Button Content="New Game"
                                                Command="{Binding StartNewGameCommand}"
                                                Margin="2"
                                                Width="160"/>
                                        <Button Content="Exit"
                                                Command="{Binding CancelCommand}"
                                                Margin="2"
                                                Width="160"/>
                                </StackPanel>
                        </StackPanel>

                        <!-- Right Panel: Category Info -->
                        <StackPanel Grid.Column="2"
                                    Margin="20,0,0,0">
                                <TextBlock Text="Category"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Accent}"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding Category}"
                                           FontSize="16"
                                           Foreground="{DynamicResource Foreground}"
                                           Padding="10"
                                           Background="{DynamicResource SecondaryBackground}"
                                           TextWrapping="Wrap"/>
                        </StackPanel>
                </Grid>
        </DockPanel>
</Window>
