<Window x:Class="HangmanWpf.Views.NewUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create New User"
        Height="400"
        Width="400"
        Background="{DynamicResource PrimaryBackground}"
        Foreground="{DynamicResource Foreground}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Border Padding="20"
            VerticalAlignment="Center">
        <StackPanel VerticalAlignment="Center">
            <!-- Title -->
            <TextBlock Text="Create New User"
                       FontSize="24"
                    FontWeight="Bold"
                       Foreground="{DynamicResource Accent}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Username Input -->
            <TextBlock Text="Username:"
                       Foreground="{DynamicResource Foreground}"
                       Margin="0,0,0,5"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10"
                     Foreground="{DynamicResource Foreground}"
                     Background="{DynamicResource SecondaryBackground}"
                     BorderBrush="{DynamicResource Border}"
                     BorderThickness="1"
                     Margin="0,0,0,15"
                     Height="35"/>

            <!-- Image Selection -->
            <TextBlock Text="Avatar Image:"
                       Foreground="{DynamicResource Foreground}"
                       Margin="0,0,0,5"/>

            <!-- Image Preview -->
            <Border BorderBrush="{DynamicResource Border}"
                    BorderThickness="1"
                    Background="{DynamicResource SecondaryBackground}"
                    Margin="0,0,0,10"
                    Height="120">
                <Image Source="{Binding ImagePath}"
                       Stretch="Uniform"
                       Margin="5"/>
            </Border>

            <!-- Browse Button -->
            <Button Content="Browse Image..."
                    Command="{Binding BrowseImageCommand}"
                    Background="{DynamicResource ButtonBackground}"
                    Foreground="{DynamicResource Foreground}"
                    Padding="10"
                    Margin="0,0,0,15"
                    Height="35"
                    FontSize="12"/>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource Error}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,15"
                       Height="30"/>

            <!-- Buttons Grid -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Button Content="Create"
                        Command="{Binding CreateUserCommand}"
                        Grid.Column="0"
                        Background="{DynamicResource Success}"
                        Foreground="{DynamicResource Foreground}"
                        Padding="10"
                        Margin="0,0,5,0"
                        Height="35"
                        FontSize="12"/>

                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Grid.Column="1"
                        Background="{DynamicResource Error}"
                        Foreground="{DynamicResource Foreground}"
                        Padding="10"
                        Margin="5,0,0,0"
                        Height="35"
                        FontSize="12"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
