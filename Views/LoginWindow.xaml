<Window x:Class="HangmanWpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hangman - Login"
        Height="500"
        Width="600"
        Background="{DynamicResource PrimaryBackground}"
        Foreground="{DynamicResource Foreground}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <!-- Title -->
            <TextBlock Text="Hangman Game"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource Accent}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <TextBlock Text="Select a User"
                       FontSize="16"
                       Foreground="{DynamicResource Foreground}"
                       Margin="0,0,0,10"/>

            <!-- User List -->
            <ListBox ItemsSource="{Binding Users}"
                     SelectedItem="{Binding SelectedUser}"
                     Background="{DynamicResource SecondaryBackground}"
                     Foreground="{DynamicResource Foreground}"
                     Height="200"
                     Margin="0,0,0,15">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                   Width="30"
                                   Height="30"
                                   Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Username}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">
                <Button Command="{Binding CreateUserCommand}"
                        Content="New User"
                        Width="100"
                        Padding="10,8"
                        Background="{DynamicResource ButtonBackground}"
                        Foreground="{DynamicResource Foreground}"
                        Margin="0,0,10,0"/>

                <Button Command="{Binding DeleteUserCommand}"
                        Content="Delete User"
                        Width="100"
                        Padding="10,8"
                        Background="{DynamicResource Error}"
                        Foreground="{DynamicResource Foreground}"
                        Margin="0,0,10,0"/>

                <Button Command="{Binding SelectUserCommand}"
                        Content="Play"
                        Width="80"
                        Padding="10,8"
                        Background="{DynamicResource Success}"
                        Foreground="{DynamicResource Foreground}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
