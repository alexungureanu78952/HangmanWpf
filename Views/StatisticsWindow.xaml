<Window x:Class="HangmanWpf.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Statistics"
        Height="500"
        Width="800"
        Background="{DynamicResource PrimaryBackground}"
        Foreground="{DynamicResource Foreground}"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Title -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Game Statistics"
                   FontSize="20"
                FontWeight="Bold"
                   Foreground="{DynamicResource Accent}"
                   Padding="20,10,20,0"/>

        <!-- DataGrid -->
        <DataGrid DockPanel.Dock="Top"
                  ItemsSource="{Binding AllStatistics}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  Background="{DynamicResource SecondaryBackground}"
                  Foreground="{DynamicResource Foreground}"
                  BorderBrush="{DynamicResource Border}"
                  Margin="20,10,20,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="User"
                        Binding="{Binding UserId}"
                        Width="*"/>
                <DataGridTextColumn Header="Category"
                        Binding="{Binding CategoryStats[0].Category}"
                        Width="*"/>
                <DataGridTextColumn Header="Played"
                        Binding="{Binding CategoryStats[0].GamesPlayed}"
                        Width="100"/>
                <DataGridTextColumn Header="Won"
                        Binding="{Binding CategoryStats[0].GamesWon}"
                        Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Close Button -->
        <Button DockPanel.Dock="Bottom"
                Content="Close"
                Command="{Binding CloseCommand}"
                Background="{DynamicResource ButtonBackground}"
                Foreground="{DynamicResource Foreground}"
                Width="100"
                Height="35"
                Margin="20"
                HorizontalAlignment="Right"/>
    </DockPanel>
</Window>
